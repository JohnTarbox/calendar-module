{
  "name": "calendar-module",
  "version": "0.0.0",
  "private": true,
  "description": "Reusable, data-agnostic, headless events-calendar module (Cloudflare-native, display-only). v0 = Month slice.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm build && pnpm typecheck && pnpm lint && pnpm test && pnpm guard:changeset",
    "guard:changeset": "node scripts/changeset-guard.mjs",
    "gen:schema": "node scripts/gen-schema.mjs",
    "changeset": "changeset",
    "storybook": "pnpm --filter @calendar-module/harness storybook",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^20.17.10",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^8.57.1",
    "eslint-plugin-no-unsanitized": "~4.0.2",
    "eslint-plugin-security": "^3.0.1",
    "fast-check": "^3.23.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
