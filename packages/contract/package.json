{
  "name": "@jonnyboats/calendar-contract",
  "version": "1.2.0",
  "description": "Versioned CalendarEvent contract + Zod validators (the SemVer-frozen seam).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JohnTarbox/calendar-module.git",
    "directory": "packages/contract"
  },
  "type": "module",
